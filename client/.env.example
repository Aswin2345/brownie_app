# API URL – use /api for local dev (Vite proxy) and for Vercel (rewrites).
# Only use a full URL like http://localhost:5000/api when running WITHOUT Vite proxy.
VITE_API_URL=/api

# Razorpay Client Key ID
VITE_RAZORPAY_KEY_ID=rzp_test_placeholder_id

# Direct UPI payment. Example: yourname@oksbi or businessname@paytm
VITE_UPI_ID=
VITE_UPI_PAYEE_NAME=Aswin Brownies
