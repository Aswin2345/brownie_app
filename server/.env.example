# Server
PORT=5000
NODE_ENV=production

# MongoDB (use Atlas URI for production: mongodb+srv://...)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/sharp-sk-brownies

# JWT (use a strong random string in production)
JWT_SECRET=change-this-to-a-long-random-secret

# Razorpay (live keys for production)
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Frontend URL (your deployed domain, no trailing slash)
FRONTEND_URL=https://your-app.vercel.app

# WhatsApp Business API (optional - leave placeholder to run in test/log mode)
WHATSAPP_TOKEN=your_whatsapp_token
WHATSAPP_PHONE_ID=your_phone_number_id
WHATSAPP_OWNER_NUMBER=919876543210
